# ============================================================
# GATOR + SHYFTMATE — Environment Template
# Copy to .env.dev or .env.prod and fill in real values
# ============================================================

ENV=dev

DATABASE_URL=postgresql+asyncpg://gator:PASSWORD@localhost:5432/gator_dev
DATABASE_URL_SYNC=postgresql://gator:PASSWORD@localhost:5432/gator_dev

JWT_SECRET=generate-with-openssl-rand-hex-32
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

LLM_PROVIDER=ollama
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

APPLE_CLIENT_ID=com.yourapp.bundle
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=./apple_auth_key.p8

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_REGION=ap-southeast-2
SES_FROM_EMAIL=no-reply@yourdomain.com
SES_FROM_NAME=Gator

SIGNALWIRE_PROJECT_ID=
SIGNALWIRE_TOKEN=
SIGNALWIRE_SPACE_URL=your-project.signalwire.com
SIGNALWIRE_PHONE_NUMBER=+61...

AWS_TRANSCRIBE_REGION=ap-southeast-2
AWS_POLLY_REGION=ap-southeast-2
POLLY_VOICE_ID=Olivia
POLLY_ENGINE=neural
POLLY_LANGUAGE_CODE=en-AU

KRONOS_BASE_URL=
KRONOS_CLIENT_ID=
KRONOS_CLIENT_SECRET=
KRONOS_COMPANY_SHORT_NAME=

SUPER_ADMIN_EMAIL=superadmin@gator.local
SUPER_ADMIN_PASSWORD=

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081
API_BASE_URL=http://localhost:8000
